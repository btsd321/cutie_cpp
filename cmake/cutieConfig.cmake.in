@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# 必需依赖
find_dependency(OpenCV REQUIRED)
find_dependency(CUDAToolkit REQUIRED)

# 可选后端依赖
if(@ENABLE_ONNXRUNTIME@)
    # 用 NOT TARGET 保护，避免重复调用导致 onnxruntimeConfig.cmake 重复创建 safeint_interface
    if(NOT TARGET onnxruntime::onnxruntime)
        find_dependency(onnxruntime CONFIG QUIET)
        if(NOT onnxruntime_FOUND)
            # 回退：自定义 Find 模块
            find_dependency(ONNXRuntime REQUIRED)
        endif()
    endif()
endif()

if(@ENABLE_TENSORRT@)
    find_dependency(TensorRT REQUIRED)
endif()

# 导入 targets
include("${CMAKE_CURRENT_LIST_DIR}/cutieTargets.cmake")

check_required_components(cutie)
