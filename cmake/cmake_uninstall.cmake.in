# cmake_uninstall.cmake.in
# Generated by CMake. Used by the 'uninstall' target to remove installed files.

if(NOT EXISTS "@CMAKE_BINARY_DIR@/install_manifest.txt")
    message(FATAL_ERROR
        "Cannot find install manifest: @CMAKE_BINARY_DIR@/install_manifest.txt\n"
        "Run 'cmake --install' first before uninstalling.")
endif()

file(READ "@CMAKE_BINARY_DIR@/install_manifest.txt" _files)
string(REGEX REPLACE "\n" ";" _files "${_files}")

foreach(_file ${_files})
    set(_f "$ENV{DESTDIR}${_file}")
    message(STATUS "Uninstalling: ${_f}")
    if(IS_SYMLINK "${_f}" OR EXISTS "${_f}")
        file(REMOVE "${_f}")
    else()
        message(STATUS "  (not found, skipping)")
    endif()
endforeach()

message(STATUS "Uninstall complete.")
